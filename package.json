{
  "name": "DTP_related",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth": "env -u PLAYWRIGHT_BROWSERS_PATH tsx scripts/auth.ts",
    "fill": "env -u PLAYWRIGHT_BROWSERS_PATH tsx scripts/fill-timesheet.ts",
    "figma-auth": "env -u PLAYWRIGHT_BROWSERS_PATH tsx scripts/figma-auth.ts",
    "capture:journey-map": "tsx scripts/capture-journey-map.ts",
    "capture:journey-maps": "tsx scripts/capture-journey-map.ts --all && open exports/dtp-accessibility-journey-maps",
    "capture:ocr": "tsx scripts/capture-map-ocr.ts",
    "capture:two": "tsx scripts/capture-two.ts",
    "stitch:two": "tsx scripts/stitch-two.ts",
    "stitch:preview": "tsx scripts/stitch-preview.ts",
    "stitch:pages": "tsx scripts/stitch-map-pages.ts",
    "validate:ocr": "tsx scripts/validate-ocr-screenshot.ts",
    "extract:journey-tables": "tsx scripts/extract-journey-tables.ts",
    "extract:journey-tables:all": "tsx scripts/extract-journey-tables.ts --all && open exports/dtp-accessibility-journey-maps",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:e2e": "FIGJAM_E2E=1 node --import tsx --test tests/e2e/*.test.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0"
  }
}
